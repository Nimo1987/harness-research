# =============================================================================
# Harness Research — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# Or export them in your shell profile (~/.zshrc / ~/.bashrc).
#
# Only TAVILY_API_KEY is strictly required. All others are optional and
# enable additional data sources. The system degrades gracefully when
# optional keys are missing.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Search Engine (at least one)
# ---------------------------------------------------------------------------
# Primary search engine. Get your key at https://tavily.com
TAVILY_API_KEY=

# Fallback search engine. Get your key at https://brave.com/search/api/
BRAVE_API_KEY=

# DuckDuckGo is used as the final fallback and requires no key.

# ---------------------------------------------------------------------------
# OPTIONAL — Financial Data
# ---------------------------------------------------------------------------
# Tushare (Chinese A-share market data). Register at https://tushare.pro
TUSHARE_TOKEN=

# ---------------------------------------------------------------------------
# OPTIONAL — Government & Regulatory Data
# ---------------------------------------------------------------------------
# SEC EDGAR requires a User-Agent string: "AppName your-email@example.com"
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=

# FRED (Federal Reserve Economic Data). Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Academic Search
# ---------------------------------------------------------------------------
# PubMed E-utilities. Free key at https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# Semantic Scholar (optional, works without key at 100 req/5min)
# Apply at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_KEY=
